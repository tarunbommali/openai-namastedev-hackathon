{
  "name": "hireflow-ai",
  "version": "2.0.0",
  "private": true,
  "description": "HireFlow AI Production",
  "scripts": {
    "install:frontend": "npm install --prefix frontend",
    "install:express": "npm install --prefix backend/express",
    "install": "npm run install:frontend && npm run install:express",
    "build:frontend": "npm run build --prefix frontend",
    "build:express": "npm run build --prefix backend/express",
    "build:ai": "python3 -m py_compile backend/python-ai/main.py",
    "build": "npm run build:frontend && npm run build:express && npm run build:ai",
    "docker:build": "docker build -t hireflow-ai .",
    "docker:run": "docker run -d --name hireflow-ai -p 80:80 -p 4000:4000 -p 8001:8001 --restart unless-stopped hireflow-ai",
    "docker:stop": "docker stop hireflow-ai",
    "docker:start": "docker start hireflow-ai",
    "docker:restart": "docker restart hireflow-ai",
    "docker:remove": "docker rm -f hireflow-ai",
    "docker:logs": "docker logs -f hireflow-ai",
    "docker:shell": "docker exec -it hireflow-ai bash",
    "deploy": "npm run docker:build && npm run docker:remove || true && npm run docker:run",
    "update": "git pull origin main && npm run deploy",
    "status": "docker ps",
    "images": "docker images",
    "clean": "docker system prune -af",
    "smoke": "bash scripts/smoke_stack.sh"
  }
}